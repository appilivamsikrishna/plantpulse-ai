# Exasol SaaS Trial connection (copy to .env.local and fill in)
# From the Exasol SaaS web console: your database's "Connection" details.
EXASOL_HOST=your-db-id.clusters.exasol.com
EXASOL_PORT=8563
EXASOL_USER=your_user
EXASOL_PASSWORD=your_password
EXASOL_SCHEMA=PLANTOPS
EXASOL_ENCRYPTION=true
# Set to false ONLY for local Exasol Community Edition with a self-signed cert.
EXASOL_TLS_VERIFY=true

# Anthropic / Claude (the thin assistant layer)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Multi-user layer (OPTIONAL): passwordless login, conversation history, and
# per-message cost logging. Only needed if you want these locally; the core
# assistant runs with just the Exasol + Anthropic vars above.
# ---------------------------------------------------------------------------
# AWS credentials for DynamoDB (conversations/messages/OTP) + SES (sign-in email)
PP_AWS_REGION=ap-south-1
PP_AWS_ACCESS_KEY_ID=
PP_AWS_SECRET_ACCESS_KEY=
# Verified SES sender for the one-time-passcode email
PP_SES_FROM=PlantPulse AI <noreply@example.com>
# Secret used to sign the session cookie (any long random string)
PP_JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated emails allowed into the /admin dashboard
PP_SUPER_ADMIN=you@example.com
# Feature flag for the conversation-history sidebar (on|off)
PP_CHAT_HISTORY=on
